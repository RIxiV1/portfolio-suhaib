# Contact form (optional — if unset, the form falls back to mailto:)
# Get a key at https://resend.com → API Keys
RESEND_API_KEY=

# Verified sender. Defaults to onboarding@resend.dev (Resend sandbox) if omitted.
# Use a verified domain address in production (e.g., noreply@yourdomain.com).
CONTACT_FROM_EMAIL=

# Inbox where contact messages land. Defaults to siteConfig.email if omitted.
CONTACT_TO_EMAIL=

# Distributed rate limiting for /api/contact. Strongly recommended in production —
# without these, the endpoint falls back to a per-worker in-memory limiter that
# does not survive multi-instance serverless. Provision via Vercel marketplace
# → Upstash Redis (free tier is sufficient for a portfolio).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
