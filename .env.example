# Contact form (optional — if unset, the form falls back to mailto:)
# Get a key at https://resend.com → API Keys
RESEND_API_KEY=

# Verified sender. Defaults to onboarding@resend.dev (Resend sandbox) if omitted.
# Use a verified domain address in production (e.g., noreply@yourdomain.com).
CONTACT_FROM_EMAIL=

# Inbox where contact messages land. Defaults to siteConfig.email if omitted.
CONTACT_TO_EMAIL=
