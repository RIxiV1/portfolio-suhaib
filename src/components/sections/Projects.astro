---
const projects = [
  {
    title: "InfoBlend",
    desc: "Chrome extension (Manifest V3). AI-powered in-page definitions, page summaries, ad blocking, intelligent form auto-fill. All client-side.",
    tags: ["JavaScript", "Chrome API", "AI"],
    github: "https://github.com/RIxiV1"
  },
  {
    title: "SubSentry",
    desc: "Subscription tracker. Your fin-bestie for tracking subs. Stop letting them ghost your bank account.",
    tags: ["TypeScript", "Frontend"],
    github: "https://github.com/RIxiV1"
  },
  {
    title: "Jarvis",
    desc: "Voice-activated AI assistant. Speech recognition + OpenAI. Plays music, opens websites, answers questions.",
    tags: ["Python", "OpenAI", "Speech Recognition"],
    github: "https://github.com/RIxiV1"
  },
  {
    title: "Resume Screening Agent",
    desc: "AI resume screener built with n8n + Lovable. PDF upload, LLM scoring, structured match report.",
    tags: ["TypeScript", "n8n", "LLMs"],
    github: "https://github.com/RIxiV1"
  },
  {
    title: "GitHub Profile / RIxiV1",
    desc: "Personal README and identity. Minimal but tells the story.",
    tags: ["Markdown", "Design"],
    github: "https://github.com/RIxiV1"
  }
];
---

<section id="work" class="container projects-section">
  <h2 class="section-title" data-stitch="slide-up">things i've built</h2>
  
  <div class="projects-grid" data-stitch="stagger-group">
    {projects.map((project, i) => (
      <div class={`project-card stagger-item ${i % 2 === 0 ? 'from-left' : 'from-right'}`}>
        <div class="card-header">
          <h3 class="project-title">{project.title}</h3>
          <p class="project-desc">{project.desc}</p>
        </div>
        <div class="card-footer">
          <div class="tags">
            {project.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          <a href={project.github} target="_blank" rel="noopener noreferrer" class="github-link" aria-label={`GitHub for ${project.title}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
          </a>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .projects-section {
    padding-top: 15vh;
    padding-bottom: 15vh;
  }
  .section-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    text-transform: lowercase;
    margin-bottom: 4rem;
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .section-title.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .projects-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  }
  
  /* Make grid asymmetrical/rhythmic via nth-child spans on larger screens */
  @media (min-width: 768px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .project-card:first-child {
      grid-column: 1 / -1;
    }
    .project-card:nth-child(4) {
      grid-column: span 1;
    }
  }

  .project-card {
    background: rgba(15, 15, 26, 0.4);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s ease, box-shadow 0.4s ease;
    will-change: transform, opacity;
    position: relative;
    overflow: hidden;
  }
  
  /* Spotlight effect layer */
  .project-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(800px circle at var(--mouse-x) var(--mouse-y), rgba(139, 92, 246, 0.15), transparent 40%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 0;
  }
  
  .project-card:hover::before {
    opacity: 1;
  }

  /* Make content sit above spotlight */
  .card-header, .card-footer {
    position: relative;
    z-index: 1;
  }
  
  /* Animation initial states */
  .stagger-item {
    opacity: 0;
  }
  .stagger-item.from-left {
    transform: translateX(-40px);
  }
  .stagger-item.from-right {
    transform: translateX(40px);
  }
  
  /* Visible state handled by stitch.js */
  .stagger-item.is-visible {
    opacity: 1;
    transform: translateX(0);
  }
  
  /* Mobile override: simple slide up */
  @media (max-width: 767px) {
    .stagger-item.from-left, .stagger-item.from-right {
      transform: translateY(30px);
    }
    .stagger-item.is-visible {
      transform: translateY(0);
    }
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--primary);
    box-shadow: 0 10px 30px -10px rgba(139, 92, 246, 0.15);
  }

  .card-header {
    margin-bottom: 2.5rem;
  }

  .project-title {
    color: var(--primary);
    font-size: 1.5rem;
    margin-bottom: 1rem;
    font-family: var(--font-mono);
  }

  .project-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    margin-top: auto;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: rgba(96, 165, 250, 0.1);
    color: var(--secondary);
    font-size: 0.75rem;
    padding: 0.3rem 0.8rem;
    border-radius: 99px;
    font-family: var(--font-mono);
    border: 1px solid rgba(96, 165, 250, 0.2);
    transition: all 0.3s ease;
  }

  .project-card:hover .tag {
    background: rgba(96, 165, 250, 0.15);
    border-color: var(--secondary);
    box-shadow: 0 0 10px rgba(96, 165, 250, 0.2);
  }

  .github-link {
    color: var(--text-muted);
    transition: color 0.3s ease;
    display: flex;
    padding-bottom: 0.2rem;
  }

  .project-card:hover .github-link {
    color: var(--text-main);
  }
</style>
