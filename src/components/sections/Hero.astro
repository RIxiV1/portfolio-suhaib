---
const nameChars = "SUHAIB".split("");

// Pre-generate random inline styles for SSR so it works immediately upon load
// Uses reproducible seeded randomness or just server generated randoms
const generateRandomTransform = () => {
  const x = Math.floor(Math.random() * 200 - 100);
  const y = Math.floor(Math.random() * 200 - 100);
  const rot = Math.floor(Math.random() * 360 - 180);
  return `transform: translate(${x}vw, ${y}vh) rotate(${rot}deg); opacity: 0;`;
};
---

<section id="hero" class="hero">
  <div class="hero-content" data-parallax="0.3">
    <h1 id="hero-name" class="hero-name" aria-label="SUHAIB">
      {nameChars.map((char) => (
        <span class="char" style={generateRandomTransform()}>{char}</span>
      ))}
    </h1>
    <p id="hero-subtitle" class="hero-subtitle" data-text="I build (and break) things for the web."></p>
  </div>
  <div class="scroll-indicator" data-parallax="0.5">
    <div class="line"></div>
  </div>
</section>

<style>
  .hero {
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: relative;
    padding: 0 1rem;
  }
  .hero-content {
    text-align: center;
  }
  .hero-name {
    font-size: clamp(3.5rem, 12vw, 8rem);
    color: var(--text-main);
    display: flex;
    justify-content: center;
    gap: 0.1em; /* little gap */
    line-height: 1;
    margin-bottom: 1.5rem;
    overflow: visible;
  }
  .char {
    display: inline-block;
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s ease-out, color 0.3s ease, text-shadow 0.3s ease;
    will-change: transform, opacity;
  }
  
  .char:hover {
    color: var(--primary);
    text-shadow: 0 0 20px rgba(139, 92, 246, 0.6);
    transform: translateY(-10px) scale(1.1) !important;
    transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), color 0.2s ease, text-shadow 0.2s ease;
  }
  .hero-subtitle {
    font-family: var(--font-mono);
    color: var(--text-muted);
    font-size: clamp(0.9rem, 3vw, 1.25rem);
    min-height: 2em;
    opacity: 0;
    transition: opacity 0.3s;
  }
  :global(.typewriter-flash) {
    color: var(--secondary);
    transition: color 0.8s ease-out;
  }
  :global(.typewriter-flash.settled) {
    color: var(--text-muted);
  }
  
  .scroll-indicator {
    position: absolute;
    bottom: 8vh;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 60px;
    background: transparent;
    overflow: hidden;
  }
  .line {
    width: 100%;
    height: 100%;
    background: var(--text-muted);
    animation: pulseDown 2.5s infinite cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  @keyframes pulseDown {
    0% { transform: translateY(-100%); opacity: 0; }
    50% { opacity: 1; }
    100% { transform: translateY(100%); opacity: 0; }
  }
</style>
