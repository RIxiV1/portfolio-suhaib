---
const skills = [
  { name: "JavaScript", size: 1.3 },
  { name: "TypeScript", size: 1.2 },
  { name: "Python", size: 1.2 },
  { name: "React", size: 1.1 },
  { name: "CSS", size: 1.1 },
  { name: "Tailwind", size: 1.0 },
  { name: "SQL", size: 1.0 },
  { name: "HTML", size: 1.0 },
  { name: "Git", size: 0.9 },
  { name: "Node.js", size: 1.1 }
];

// Shuffle array for loose cloud effect
const shuffled = [...skills].sort(() => 0.5 - Math.random());
---

<section id="skills" class="container skills-section">
  <h2 class="section-title" data-stitch="slide-up">what i work with</h2>
  
  <div class="tag-cloud" data-stitch="burst-group">
    {shuffled.map(skill => (
      <span class="burst-tag" style={`font-size: ${skill.size}rem;`}>
        {skill.name}
      </span>
    ))}
  </div>
</section>

<style>
  .skills-section {
    padding-top: 10vh;
    padding-bottom: 15vh;
  }
  .section-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    text-transform: lowercase;
    margin-bottom: 4rem;
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .section-title.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: clamp(1rem, 3vw, 2.5rem);
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 0;
  }

  .burst-tag {
    font-family: var(--font-mono);
    color: var(--text-main);
    opacity: 0;
    /* initial transform is scaled down, will trigger to scale 1.0 */
    transform: scale(0.5); 
    transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.6s ease;
    will-change: transform, opacity;
  }
  
  .burst-tag.is-visible {
    animation: float-tag 6s ease-in-out infinite alternate;
  }

  @keyframes float-tag {
    0% { transform: translateY(0px) scale(1); }
    100% { transform: translateY(-8px) scale(1.02); }
  }
  
  /* Mobile simple override */
  @media (max-width: 767px) {
    .burst-tag {
      transform: translateY(20px);
      transition: transform 0.6s ease, opacity 0.6s ease;
    }
  }

  .burst-tag:hover {
    color: var(--secondary);
    text-shadow: 0 0 10px rgba(96, 165, 250, 0.4);
    transform: scale(1.1) rotate(-2deg) !important;
    transition: transform 0.2s ease, color 0.2s ease;
  }
  
  /* Make sure reduced-motion doesn't snap strangely after hover */
  :root.reduced-motion .burst-tag:hover {
    transform: none !important;
  }
</style>
