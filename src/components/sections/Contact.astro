---
---
<section id="contact" class="container contact-section">
  <div class="contact-content glass-panel" data-stitch="slide-up">
    <h2 class="contact-title">let's talk</h2>
    <p class="contact-sub">I'm currently open to full-time roles and freelance projects.</p>
    
    <div class="links-container">
      <a href="https://www.linkedin.com/in/shaiksuhaib" target="_blank" rel="noopener noreferrer" class="contact-link purple-btn">
        <svg class="border-svg" width="100%" height="100%">
          <rect class="border-rect" x="0" y="0" width="100%" height="100%" rx="8" ry="8" />
        </svg>
        <span>LinkedIn</span>
      </a>
      
      <a href="https://github.com/RIxiV1" target="_blank" rel="noopener noreferrer" class="contact-link blue-btn">
        <svg class="border-svg" width="100%" height="100%">
          <rect class="border-rect" x="0" y="0" width="100%" height="100%" rx="8" ry="8" />
        </svg>
        <span>GitHub</span>
      </a>

      <a href="mailto:shaiksuhaib360@gmail.com" class="contact-link green-btn">
        <svg class="border-svg" width="100%" height="100%">
          <rect class="border-rect" x="0" y="0" width="100%" height="100%" rx="8" ry="8" />
        </svg>
        <span>Email</span>
      </a>

      <a href="https://medium.com/@shaiksuhaib360" target="_blank" rel="noopener noreferrer" class="contact-link pink-btn">
        <svg class="border-svg" width="100%" height="100%">
          <rect class="border-rect" x="0" y="0" width="100%" height="100%" rx="8" ry="8" />
        </svg>
        <span>Medium</span>
      </a>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding-top: 15vh;
    padding-bottom: 20vh;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .contact-content {
    border-radius: 12px;
    padding: 4rem 2rem;
    text-align: center;
    max-width: 600px;
    width: 100%;
    
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s ease-out, transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .contact-content.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .contact-title {
    font-family: var(--font-mono);
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: var(--text-main);
    margin-bottom: 1rem;
  }

  .contact-sub {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-bottom: 3rem;
  }

  .links-container {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .contact-link {
    position: relative;
    padding: 1rem 2.5rem;
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--text-main);
    background: rgba(15, 15, 26, 0.8);
    display: inline-block;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease;
    will-change: transform;
  }

  .contact-link:hover {
    transform: scale(1.05) translateY(-4px);
  }

  .contact-link span {
    position: relative;
    z-index: 2;
  }

  .border-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .border-rect {
    fill: none;
    stroke-width: 2;
    stroke-dasharray: 400; /* Approximate perimeter, will be updated by stroke-dashoffset */
    stroke-dashoffset: 400;
    transition: stroke-dashoffset 0.6s cubic-bezier(0.4, 0, 0.2, 1), stroke 0.3s ease;
  }

  /* Different colors for buttons */
  .purple-btn .border-rect {
    stroke: rgba(139, 92, 246, 0.3); /* Default faded primary */
    stroke-dashoffset: 0; 
  }
  .blue-btn .border-rect {
    stroke: rgba(96, 165, 250, 0.3); /* Default faded secondary */
    stroke-dashoffset: 0;
  }
  .green-btn .border-rect {
    stroke: rgba(16, 185, 129, 0.3); /* Emerald Green */
    stroke-dashoffset: 0;
  }
  .pink-btn .border-rect {
    stroke: rgba(236, 72, 153, 0.3); /* Pink */
    stroke-dashoffset: 0;
  }

  .purple-btn:hover .border-rect {
    stroke: var(--primary);
    stroke-dashoffset: -400; /* Animates sweep */
  }
  
  .blue-btn:hover .border-rect {
    stroke: var(--secondary);
    stroke-dashoffset: -400;
  }

  .green-btn:hover .border-rect {
    stroke: #10b981;
    stroke-dashoffset: -400;
  }

  .pink-btn:hover .border-rect {
    stroke: #ec4899;
    stroke-dashoffset: -400;
  }

  /* Fallback glow */
  .purple-btn:hover {
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.2);
  }
  .blue-btn:hover {
    box-shadow: 0 0 20px rgba(96, 165, 250, 0.2);
  }
  .green-btn:hover {
    box-shadow: 0 0 20px rgba(16, 185, 129, 0.2);
  }
  .pink-btn:hover {
    box-shadow: 0 0 20px rgba(236, 72, 153, 0.2);
  }
</style>
